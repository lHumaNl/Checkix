# FastAPI application settings
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database settings
DATABASE_URL=postgresql+asyncpg://checkix:checkix@localhost:5432/checkix
DATABASE_URL_SYNC=postgresql://checkix:checkix@localhost:5432/checkix

# Cache and websocket ticket storage
REDIS_URL=redis://localhost:6379/0

# JSON array of allowed browser origins
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:5173"]
